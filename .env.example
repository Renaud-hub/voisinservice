# =============================================
# VOISINSERVICE — Variables d'Environnement
# =============================================
# Copier ce fichier en .env et remplir les valeurs

# Serveur
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# Base de données MongoDB
MONGODB_URI=mongodb://localhost:27017/voisinservice
# En production (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/voisinservice

# JWT Secret (générer une clé forte en production)
JWT_SECRET=voisinservice_jwt_secret_change_in_production_2024
JWT_EXPIRE=7d

# ============================================
# MTN MoMo API (https://momodeveloper.mtn.com)
# ============================================
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# Production: https://proxy.momoapi.mtn.com

MTN_MOMO_COLLECTIONS_PRIMARY_KEY=your_collections_primary_key_here
MTN_MOMO_COLLECTIONS_SECONDARY_KEY=your_collections_secondary_key_here
MTN_MOMO_DISBURSEMENTS_PRIMARY_KEY=your_disbursements_primary_key_here

MTN_MOMO_API_USER=your_api_user_uuid_here
MTN_MOMO_API_KEY=your_api_key_here

MTN_MOMO_ENVIRONMENT=sandbox
# Production: production

MTN_MOMO_CURRENCY=XOF
MTN_MOMO_CALLBACK_URL=https://yourapp.com/api/payments/momo/callback

# ============================================
# Cloudinary (Upload images)
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Email (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@voisinservice.com
FROM_NAME=VoisinService

# ============================================
# Admin
# ============================================
ADMIN_EMAIL=admin@voisinservice.com
ADMIN_PASSWORD=Admin@1234
COMMISSION_RATE=0.10
